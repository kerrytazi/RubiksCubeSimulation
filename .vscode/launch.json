{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Debug executable 'app'",
			"type": "lldb",
			"request": "launch",
			"cargo": {
				"args": [
					"run",
					"--bin=app"
				]
			},
			"args": [],
			"terminal": "console",
			"postDebugTask": "Close Debug Terminal"
		},
		{
			"name": "Debug unit tests in executable 'app'",
			"type": "lldb",
			"request": "launch",
			"cargo": {
				"args": [
					"test",
					"--bin=app"
				]
			},
			"terminal": "console",
			"postDebugTask": "Close Debug Terminal"
		}
	]
}
